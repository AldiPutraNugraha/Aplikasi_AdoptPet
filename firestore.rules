rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSelf(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isOwner() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'owner';
    }

    function isAdopter() {
      return signedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'adopter';
    }

    function hasCompletedProfile(data) {
      return data.phoneNumber is string
        && data.phoneNumber.matches('.*[0-9].*')
        && data.fullAddress is string
        && data.fullAddress.matches('.*[A-Za-z0-9].*');
    }

    function isEditablePetDetailsUpdate() {
      return request.resource.data.status == resource.data.status
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'species',
          'estimatedBreed',
          'primaryColor',
          'secondaryColor',
          'furPattern',
          'age',
          'sex',
          'description',
          'photoUrls',
          'vaccinationStatus',
          'sterilizationStatus',
          'medicalHistory',
          'healthProofUrls',
          'fullAddress',
          'coordinates',
          'aiAttributes',
          'updatedAt'
        ])
        && request.resource.data.updatedAt == request.time;
    }

    function isAdoptionPetTransition(petId) {
      let requestId = request.resource.data.adoptedRequestId;
      let requestPath = /databases/$(database)/documents/adoptionRequests/$(requestId);

      return resource.data.status == 'available'
        && request.resource.data.status == 'adopted'
        && request.resource.data.adoptedById is string
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'adoptedById',
          'adoptedRequestId',
          'updatedAt'
        ])
        && request.resource.data.updatedAt == request.time
        && get(requestPath).data.status == 'pending'
        && get(requestPath).data.petId == petId
        && get(requestPath).data.ownerId == request.auth.uid
        && get(requestPath).data.adopterId == request.resource.data.adoptedById
        && getAfter(requestPath).data.status == 'accepted'
        && getAfter(requestPath).data.decidedAt == request.time;
    }

    match /users/{userId} {
      allow create: if isSelf(userId)
        && request.resource.data.id == userId
        && request.resource.data.role in ['owner', 'adopter']
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email is string
        && request.resource.data.phoneNumber is string
        && request.resource.data.fullAddress is string
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow read: if signedIn();
      allow update: if isSelf(userId)
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email
        && request.resource.data.role == resource.data.role
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'phoneNumber',
          'fullAddress',
          'coordinates',
          'fcmToken',
          'updatedAt'
        ])
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(['phoneNumber', 'fullAddress'])
          || hasCompletedProfile(request.resource.data)
        );
    }

    match /pets/{petId} {
      allow read: if signedIn();
      allow create: if isOwner() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isOwner()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.createdAt == resource.data.createdAt
        && (isEditablePetDetailsUpdate() || isAdoptionPetTransition(petId));
      allow delete: if isOwner()
        && resource.data.ownerId == request.auth.uid
        && resource.data.status == 'available';
    }

    match /adoptionRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.ownerId == request.auth.uid || resource.data.adopterId == request.auth.uid);
      allow create: if isAdopter()
        && request.resource.data.adopterId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly([
          'petId',
          'ownerId',
          'adopterId',
          'screeningAnswers',
          'status',
          'requestedAt'
        ])
        && request.resource.data.screeningAnswers.keys().hasOnly([
          'adoptionReason',
          'petCareExperience',
          'livingCondition',
          'dailyCareAvailability',
          'whatsappContact'
        ])
        && request.resource.data.screeningAnswers.adoptionReason is string
        && request.resource.data.screeningAnswers.adoptionReason.size() > 0
        && request.resource.data.screeningAnswers.petCareExperience is string
        && request.resource.data.screeningAnswers.petCareExperience.size() > 0
        && request.resource.data.screeningAnswers.livingCondition is string
        && request.resource.data.screeningAnswers.livingCondition.size() > 0
        && request.resource.data.screeningAnswers.dailyCareAvailability is string
        && request.resource.data.screeningAnswers.dailyCareAvailability.size() > 0
        && request.resource.data.screeningAnswers.whatsappContact is string
        && request.resource.data.screeningAnswers.whatsappContact.size() > 0
        && request.resource.data.requestedAt == request.time
        && get(/databases/$(database)/documents/pets/$(request.resource.data.petId)).data.ownerId == request.resource.data.ownerId
        && get(/databases/$(database)/documents/pets/$(request.resource.data.petId)).data.status == 'available';
      allow update: if isOwner()
        && resource.data.ownerId == request.auth.uid
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'ownerNote', 'decidedAt'])
        && request.resource.data.status in ['accepted', 'rejected']
        && request.resource.data.ownerNote is string
        && request.resource.data.decidedAt == request.time
        && (
          request.resource.data.status == 'rejected'
          || (
            get(/databases/$(database)/documents/pets/$(resource.data.petId)).data.status == 'available'
            && getAfter(/databases/$(database)/documents/pets/$(resource.data.petId)).data.status == 'adopted'
            && getAfter(/databases/$(database)/documents/pets/$(resource.data.petId)).data.adoptedById == resource.data.adopterId
            && getAfter(/databases/$(database)/documents/pets/$(resource.data.petId)).data.adoptedRequestId == requestId
          )
        );
    }

    match /postAdoptionReports/{reportId} {
      allow read: if signedIn()
        && (resource.data.ownerId == request.auth.uid || resource.data.adopterId == request.auth.uid);
      allow create: if false;
      allow update: if signedIn()
        && resource.data.adopterId == request.auth.uid
        && resource.data.status in ['due', 'late']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'conditionPhotoPaths',
          'conditionNote',
          'status',
          'submittedAt'
        ])
        && request.resource.data.status == 'submitted'
        && request.resource.data.conditionPhotoPaths is list
        && request.resource.data.conditionPhotoPaths.size() == 1
        && request.resource.data.conditionPhotoPaths[0] is string
        && request.resource.data.conditionPhotoPaths[0].matches('reports/' + request.auth.uid + '/' + reportId + '/.*')
        && request.resource.data.conditionNote is string
        && request.resource.data.submittedAt == request.time;
    }

    match /aiSearchLogs/{logId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    match /vocabularies/{docId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /breeds/{species} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
